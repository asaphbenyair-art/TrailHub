generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  GUIDE
  TRIP_MANAGER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXTREME
}

enum TripStatus {
  DRAFT
  PENDING_REVIEW
  REJECTED
  OPEN
  FULL
  POSTPONED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLIST
  CANCELLED
  INTERESTED
  CONDITIONAL
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
}

enum NotificationType {
  TRIP_UPDATED
  TRIP_CANCELLED
  QUESTION_ANSWERED
  NEW_MESSAGE
  NEW_TRIP_FROM_GUIDE
  RIDESHARE_UPDATE
  PAYMENT_UPDATE
}

enum TripType {
  DAY_HIKE
  EXPEDITION
  MULTI_SITE
  SELF_GUIDED
}

enum ComplaintStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum TripVisibility {
  PUBLIC
  PRIVATE
}

enum RegistrationMode {
  FULL_ONLY
  INDIVIDUAL_DAYS
  FLEXIBLE
}

enum TripGuideRole {
  PRIMARY
  SECONDARY
  EQUAL
}

enum RideDirection {
  ROUND_TRIP
  ONE_WAY
}

// ─── NextAuth required models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime? // updated on each sign-in (for the daily summary)

  gender                String?
  birthYear             Int?
  bio                   String?  @db.Text
  slogan                String?  // personal tagline shown on participant cards
  calendarPref          String   @default("gregorian") // 'gregorian' | 'hebrew' date display
  themePref             String?  // 'dark' | 'light' | null (null → system/default)
  companyLogo           String?  // guide/trip-manager company logo (shown on trip cards)
  phone                 String?
  fitnessLevel          String?
  preferredRegions      String[]
  preferredDifficulties String[]
  preferredTripLengthKm Int?
  preferredDays         Int[]
  activeMode            String?  // "guide" | "hiker" — last active mode

  accounts      Account[]
  sessions      Session[]
  guide         Guide?
  registrations Registration[]
  reviews       Review[]
  favorites     FavoriteTrip[]
  notifications        Notification[]
  questions            TripQuestion[]
  questionReplies      TripQuestionReply[]
  broadcasts           Broadcast[]
  sentMessages         ChatMessage[] @relation("SentMessages")
  receivedMessages     ChatMessage[] @relation("ReceivedMessages")
  follows              GuideFollow[]
  managedTrips         TripManager[]
  rideOffers           RideshareOffer[]
  rideClaims           RideshareClaim[]
  rideshareRequests    RideshareRequest[]
  purchases            SelfGuidedPurchase[]
  complaints           Complaint[]
}

model SelfGuidedPurchase {
  id            String   @id @default(cuid())
  tripId        String
  userId        String
  price         Float
  purchasedAt   DateTime @default(now())
  accessExpiresAt DateTime?
  sharedWith    String[] // emails of up to 3 additional people
  revoked       Boolean  @default(false)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@index([tripId])
}

model Complaint {
  id        String          @id @default(cuid())
  tripId    String
  userId    String
  category  String
  body      String          @db.Text
  status    ComplaintStatus @default(OPEN)
  createdAt DateTime        @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([status])
}

model Guide {
  id             String  @id @default(cuid())
  userId         String  @unique
  bio            String? @db.Text
  location       String?
  phone          String?
  rating         Float   @default(0)
  reviewCount    Int     @default(0)
  isVerified     Boolean @default(false)
  yearsActive    Int?

  headline             String?
  specialtyRegions     String[]
  interests            String[]
  youtubeUrl           String?
  podcastUrl           String?
  trainingInstitution  String?
  selfGuidedRating     Float   @default(0)
  selfGuidedReviewCount Int    @default(0)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trips        Trip[]
  coupons      Coupon[]
  followers    GuideFollow[]
  tripGuides   TripGuide[]
}

model GuideFollow {
  id        String   @id @default(cuid())
  userId    String
  guideId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([userId, guideId])
  @@index([guideId])
}

model Trip {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  region      String
  difficulty  Difficulty @default(MEDIUM)
  status      TripStatus @default(DRAFT)

  date        DateTime
  startTime   String
  estimatedEndTime String? // "HH:MM" — reviews unlock 1h before this
  durationMin Int
  distanceKm  Float

  price    Float
  maxSpots Int
  spotsBooked Int @default(0)

  images    String[]
  latitude  Float?
  longitude Float?

  tripType  TripType @default(DAY_HIKE)
  endDate   DateTime?
  priceTiers Json?
  routeGpx          String? @db.Text
  waypointsJson     Json?
  individualDayPrice Float?

  visibility       TripVisibility   @default(PUBLIC)
  registrationMode RegistrationMode @default(FULL_ONLY)
  registrationFields Json?
  routeType        String?
  minAge           Int?
  maxAge           Int?
  fitnessLevel     String?
  minSpots         Int?

  // Attribute tags + multi-person + source materials
  attributeTags    String[]
  genderRestriction String? @default("ALL") // "ALL" | "MEN" | "WOMEN" (display only, not enforced)
  multiPersonMode  String?  // "simple" | "detailed"
  sourceMaterials  Json?    // [{ type:"pdf"|"link", url, title }]
  sourceMaterialsVisibility String? // "preview" | "during"

  // Self-guided trip fields
  unlimitedCapacity Boolean @default(false)
  accessWindowDays  Int?

  // Postponed state
  postponeCategory  String?
  postponeReason    String?  @db.Text

  meetingPoint    String?
  healthDeclarationUrl String? // guide-uploaded health-declaration PDF
  waypoints       String? @db.Text
  whatToBring     String?
  cancellationPolicy String? @db.Text
  approvalNote       String? @db.Text

  guideId String
  guide   Guide  @relation(fields: [guideId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]
  reviews       Review[]
  favorites     FavoriteTrip[]
  notifications Notification[]
  questions     TripQuestion[]
  broadcasts    Broadcast[]
  chatMessages  ChatMessage[]
  days          TripDay[]
  coupons       Coupon[]
  guides        TripGuide[]
  managers      TripManager[]
  rideOffers    RideshareOffer[]
  rideshareRequests RideshareRequest[]
  purchases     SelfGuidedPurchase[]
  complaints    Complaint[]

  @@index([guideId])
  @@index([status])
  @@index([date])
  @@index([region])
  @@index([visibility])
}

model TripGuide {
  id        String        @id @default(cuid())
  tripId    String
  guideId   String
  role      TripGuideRole @default(PRIMARY)
  createdAt DateTime      @default(now())

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([tripId, guideId])
  @@index([tripId])
  @@index([guideId])
}

model TripManager {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

model Registration {
  id               String             @id @default(cuid())
  tripId           String
  userId           String
  status           RegistrationStatus @default(PENDING)
  paymentStatus    PaymentStatus      @default(PENDING)
  participantCount Int                @default(1)
  totalPrice       Float
  notes            String?            @db.Text
  waitlistPosition Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Dynamic registration field answers + signed policy
  fieldAnswers Json?
  signedPolicy Boolean @default(false)
  healthDeclaration String? @db.Text // hiker's signed "אני חותם על כך ש..." confirmation

  // Interest / conditional interest
  interestThreshold Int?
  conditions        Json?
  autoRegister      Boolean @default(false)

  // Journey day selection (for INDIVIDUAL_DAYS / FLEXIBLE modes)
  dayNumbers Int[]

  // Payment (Stripe-shaped state machine)
  paymentIntentId     String?
  authorizedAt        DateTime?
  capturedAt          DateTime?
  refundedAt          DateTime?
  alertThresholdHours Int?
  alertSentAt         DateTime?

  // Comp (free volunteer invite) + multi-person detail
  isComp              Boolean   @default(false)
  participantsDetail  Json?     // [{ name, fieldAnswers }] for detailed multi-person

  // Privacy: hide name from the fellow-registrants list (shows "משתתף אנונימי")
  anonymous           Boolean   @default(false)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@index([tripId])
}

model Review {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model FavoriteTrip {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}

// ─── Communication models ────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tripId    String?
  type      NotificationType
  title     String
  body      String
  link      String?          // deep link path, e.g. /trips/<id>#qa-<qid>
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, read])
}

model TripQuestion {
  id         String    @id @default(cuid())
  tripId     String
  userId     String
  body       String    @db.Text
  answer     String?   @db.Text
  answeredAt DateTime?
  isPrivate  Boolean   @default(false) // private = visible only to guide + asker
  createdAt  DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TripQuestionReply[]

  @@index([tripId])
}

// Lightweight trip-view log (for the daily summary "trips viewed" metric).
model TripView {
  id        String   @id @default(cuid())
  tripId    String
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Guide broadcast/announcement history (persisted, shown on the trip page).
model Broadcast {
  id             String   @id @default(cuid())
  tripId         String
  senderId       String
  body           String   @db.Text
  isCancellation Boolean  @default(false)
  createdAt      DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// Threaded follow-up replies on a Q&A question (hiker ↔ guide back-and-forth).
model TripQuestionReply {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  question TripQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  tripId     String
  fromUserId String
  toUserId   String
  body       String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  trip     Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromUser User @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([tripId, fromUserId])
  @@index([tripId, toUserId])
}

model TripDay {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  title     String?
  description String? @db.Text
  distanceKm  Float?
  durationMin Int?
  startPoint  String?
  endPoint    String?
  waypoints   String? @db.Text

  date        DateTime?
  startTime   String?
  isRestDay   Boolean  @default(false)
  gpxData     String?  @db.Text
  equipment   String?
  guides      Json?    // [{ guideId, role }] per-day guide assignment
  price       Float?
  waypointsJson Json?
  sourceMaterials Json?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@unique([tripId, dayNumber])
}

// ─── Rideshare board ─────────────────────────────────────────────────────────

model RideshareOffer {
  id            String        @id @default(cuid())
  tripId        String
  posterId      String
  departureCity String
  spots         Int           @default(1)
  direction     RideDirection @default(ROUND_TRIP)
  costSharing   Boolean       @default(false)
  note          String?
  isCancelled   Boolean       @default(false)
  createdAt     DateTime      @default(now())

  trip   Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  poster User             @relation(fields: [posterId], references: [id], onDelete: Cascade)
  claims RideshareClaim[]

  @@index([tripId])
  @@index([posterId])
}

model RideshareClaim {
  id        String   @id @default(cuid())
  offerId   String
  userId    String
  createdAt DateTime @default(now())

  offer RideshareOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([offerId, userId])
  @@index([offerId])
  @@index([userId])
}

model RideshareRequest {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discountPct Int
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  isComp      Boolean  @default(false)
  guideId     String
  tripId      String?
  createdAt   DateTime @default(now())

  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  trip  Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([guideId])
  @@index([tripId])
}
